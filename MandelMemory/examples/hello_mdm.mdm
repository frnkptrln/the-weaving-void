# MandelMemory Example: Output 'M' (77)
# memory[0] = 7, memory[0.1] = memory[0] * 11

# Set counter to 7 at T(0)
T(0)
+++++++

# while memory[z] > 0
[
  T(0.1)      # z = 0^2 + 0.1 = 0.1
  +++++++++++ # memory[0.1] += 11
  T(-0.01)    # z = 0.1^2 - 0.01 = 0
  -           # memory[0] -= 1
]

# Final Move and Output
T(0.1)
!
